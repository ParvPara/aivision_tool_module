profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and local version file (.python-version) isn't globally ignored.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a setup.py file or pip install -e ., you can choose to ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock

